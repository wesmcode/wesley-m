{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "services.wesley-m.com" }],
      "destination": "/services/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "contact.wesley-m.com" }],
      "destination": "/contact/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "resume.wesley-m.com" }],
      "destination": "/resume/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "work.wesley-m.com" }],
      "destination": "/work/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "blog.wesley-m.com" }],
      "destination": "/blog/:path*"
    }
  ]
}
