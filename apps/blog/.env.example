# Postgres connection string. Either DATABASE_URI or POSTGRES_URL works
# (POSTGRES_URL is the env var Vercel's Neon integration injects).
DATABASE_URI=postgresql://user:password@host/database?sslmode=require

# 32-byte hex secret used to sign Payload tokens.
PAYLOAD_SECRET=replace-with-32-byte-hex

# Public origin of the deployed blog.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Required in production only. When set, Media uploads go to Vercel Blob.
# When unset (local dev), uploads fall back to the local `media/` directory.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
